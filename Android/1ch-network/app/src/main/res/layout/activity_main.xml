<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tg_black"
    tools:context=".MainActivity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/myRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layoutManager="LinearLayoutManager"
        tools:listitem="@layout/image_view"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/messageField"/>

    <EditText
        android:id="@+id/messageField"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:inputType="text"
        android:textColorHint="@color/tg_grey"
        android:textColor="@color/tg_white"
        android:background="@null"
        app:layout_constraintStart_toEndOf="@id/imageButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@id/imageButton"
        app:layout_constraintEnd_toStartOf="@id/messageButton"
        android:importantForAutofill="no"
        android:hint="@string/messageField"/>

    <ImageButton
        android:id="@+id/imageButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/tg_black"
        android:contentDescription="@string/todo"
        android:src="@drawable/clip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/messageButton"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:src="@drawable/airplane"
        android:backgroundTint="@color/tg_black"
        android:contentDescription="@string/todo"
        app:layout_constraintTop_toTopOf="@id/imageButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/upButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/up3"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="2dp"
        android:backgroundTint="@color/tg_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/todo" />

    <ImageButton
        android:id="@+id/refreshButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/refresh"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="-4dp"
        android:backgroundTint="@color/tg_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/downButton"
        android:contentDescription="@string/todo" />

    <ImageButton
        android:id="@+id/downButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/down"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="-4dp"
        android:backgroundTint="@color/tg_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/upButton"
        android:contentDescription="@string/todo" />

</androidx.constraintlayout.widget.ConstraintLayout>
